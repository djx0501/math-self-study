<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>初中数学重难点自学</title>
<meta name="description" content="初中数学重难点知识自学平台，覆盖初一至初三全部核心考点，每个知识点含多道典型例题与分步解析">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:"PingFang SC","Microsoft YaHei","Hiragino Sans GB",system-ui,-apple-system,sans-serif;background:#f0f4f9;color:#1e293b;line-height:1.7;min-height:100vh}
:root{--blue:#3b82f6;--blue-light:#eff6ff;--blue-dark:#1d4ed8;--green:#10b981;--green-light:#ecfdf5;--green-dark:#059669;--amber:#f59e0b;--amber-light:#fffbeb;--red:#ef4444;--red-light:#fef2f2;--purple:#8b5cf6;--purple-light:#f5f3ff;--slate-50:#f8fafc;--slate-100:#f1f5f9;--slate-200:#e2e8f0;--slate-300:#cbd5e1;--slate-400:#94a3b8;--slate-500:#64748b;--slate-600:#475569;--slate-700:#334155;--slate-800:#1e293b;--slate-900:#0f172a;--radius:12px;--radius-sm:8px;--shadow-sm:0 1px 2px rgba(0,0,0,.05);--shadow:0 1px 3px rgba(0,0,0,.1);--shadow-md:0 4px 6px rgba(0,0,0,.07);--shadow-lg:0 10px 15px rgba(0,0,0,.1)}

.topbar{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--slate-200);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:56px}
.topbar .logo{display:flex;align-items:center;gap:10px;font-size:1.2rem;font-weight:700;color:var(--blue-dark);text-decoration:none}
.topbar nav{display:flex;gap:4px}
.topbar nav a{padding:8px 16px;border-radius:var(--radius-sm);color:var(--slate-600);text-decoration:none;font-size:.9rem;font-weight:500;transition:all .15s}
.topbar nav a:hover,.topbar nav a.active{background:var(--blue-light);color:var(--blue)}
.topbar .stats-summary{display:flex;align-items:center;gap:16px;font-size:.85rem;color:var(--slate-500)}
.topbar .stats-summary strong{color:var(--blue);font-size:1rem}

.hero{background:linear-gradient(135deg,#1e3a5f 0%,#2563eb 50%,#7c3aed 100%);color:#fff;padding:64px 24px;text-align:center;position:relative;overflow:hidden}
.hero .hero-inner{position:relative;max-width:720px;margin:0 auto}
.hero h1{font-size:2.4rem;font-weight:800;margin-bottom:12px}
.hero p{font-size:1.1rem;opacity:.9;margin-bottom:28px}
.hero .hero-badges{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.hero .hero-badge{background:rgba(255,255,255,.15);backdrop-filter:blur(4px);border:1px solid rgba(255,255,255,.2);border-radius:999px;padding:8px 20px;font-size:.9rem;font-weight:500}

.container{max-width:1280px;margin:0 auto;padding:32px 24px}
.section-title{font-size:1.5rem;font-weight:700;color:var(--slate-800);margin-bottom:20px;display:flex;align-items:center;gap:8px}
.section-title .count{font-size:.85rem;font-weight:500;color:var(--slate-400);margin-left:auto}

.grade-tabs{display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap}
.grade-tab{padding:10px 24px;border-radius:999px;border:2px solid var(--slate-200);background:#fff;color:var(--slate-600);font-size:.95rem;font-weight:600;cursor:pointer;transition:all .15s}
.grade-tab:hover{border-color:var(--blue);color:var(--blue)}
.grade-tab.active{background:var(--blue);border-color:var(--blue);color:#fff}

.topics-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:16px;margin-bottom:40px}
.topic-card{background:#fff;border-radius:var(--radius);border:1px solid var(--slate-200);padding:24px;cursor:pointer;transition:all .2s}
.topic-card:hover{box-shadow:var(--shadow-md);border-color:var(--blue);transform:translateY(-2px)}
.topic-card .topic-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px}
.topic-card .topic-icon{width:42px;height:42px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.topic-card .topic-icon.algebra{background:#eff6ff;color:var(--blue)}
.topic-card .topic-icon.geometry{background:#f5f3ff;color:var(--purple)}
.topic-card .topic-icon.stats{background:#ecfdf5;color:var(--green)}
.topic-card .topic-icon.func{background:#fffbeb;color:var(--amber)}
.topic-card .topic-level{font-size:.75rem;padding:3px 10px;border-radius:999px;font-weight:600}
.topic-card .topic-level.basic{background:var(--green-light);color:var(--green-dark)}
.topic-card .topic-level.medium{background:var(--amber-light);color:#b45309}
.topic-card .topic-level.hard{background:var(--red-light);color:var(--red)}
.topic-card h3{font-size:1.05rem;font-weight:700;color:var(--slate-800);margin-bottom:6px}
.topic-card .topic-desc{font-size:.85rem;color:var(--slate-500);line-height:1.6;margin-bottom:12px}
.topic-card .topic-tags{display:flex;gap:6px;flex-wrap:wrap}
.topic-card .topic-tag{font-size:.75rem;padding:2px 10px;border-radius:999px;background:var(--slate-100);color:var(--slate-500)}
.topic-card .topic-progress{height:4px;background:var(--slate-100);border-radius:2px;margin-top:14px;overflow:hidden}
.topic-card .topic-progress-bar{height:100%;background:var(--green);border-radius:2px;transition:width .3s}

.detail-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;align-items:center;justify-content:center;padding:24px}
.detail-overlay.open{display:flex}
.detail-panel{background:#fff;border-radius:var(--radius);width:100%;max-width:880px;max-height:88vh;overflow-y:auto;box-shadow:var(--shadow-lg)}
.detail-panel .dp-top{position:sticky;top:0;background:#fff;z-index:2;padding:24px 32px 0;display:flex;align-items:flex-start;justify-content:space-between}
.detail-panel .dp-close{width:36px;height:36px;border-radius:50%;border:none;background:var(--slate-100);font-size:1.3rem;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.detail-panel .dp-close:hover{background:var(--slate-200)}
.detail-panel .dp-body{padding:0 32px 32px}
.detail-panel .dp-title{font-size:1.6rem;font-weight:800;color:var(--slate-800);margin-bottom:8px;padding-right:16px}
.detail-panel .dp-meta{display:flex;gap:12px;margin-bottom:24px;font-size:.85rem;color:var(--slate-500)}
.detail-panel .dp-content h4{font-size:1.1rem;font-weight:700;color:var(--slate-700);margin:24px 0 10px}
.detail-panel .dp-content p{font-size:.95rem;color:var(--slate-600);margin-bottom:12px;line-height:1.8}
.detail-panel .dp-content .formula-block{background:var(--slate-50);border-left:3px solid var(--blue);padding:16px 20px;border-radius:0 var(--radius-sm) var(--radius-sm) 0;margin:16px 0;font-size:1.05rem;color:var(--slate-800)}
.detail-panel .dp-content .tip-block{background:var(--amber-light);border-left:3px solid var(--amber);padding:14px 18px;border-radius:0 var(--radius-sm) var(--radius-sm) 0;margin:16px 0;font-size:.9rem;color:#92400e;line-height:1.7}
.detail-panel .dp-content .example-block{background:var(--green-light);border-left:3px solid var(--green);padding:14px 18px;border-radius:0 var(--radius-sm) var(--radius-sm) 0;margin:16px 0;font-size:.9rem;color:var(--green-dark);line-height:1.8}
.detail-panel .dp-steps{counter-reset:step;list-style:none;padding:0}
.detail-panel .dp-steps li{counter-increment:step;position:relative;padding-left:40px;margin-bottom:14px;font-size:.9rem;color:var(--slate-600);line-height:1.7}
.detail-panel .dp-steps li::before{content:counter(step);position:absolute;left:0;top:0;width:27px;height:27px;border-radius:50%;background:var(--blue);color:#fff;font-size:.8rem;font-weight:700;display:flex;align-items:center;justify-content:center}

/* detail examples list */
.detail-examples{margin-top:8px}
.detail-examples h4{margin-bottom:16px}
.example-card{background:var(--slate-50);border:1px solid var(--slate-200);border-radius:var(--radius-sm);padding:16px 20px;margin-bottom:12px}
.example-card .ex-q{font-weight:600;color:var(--slate-700);margin-bottom:8px;font-size:.95rem;line-height:1.6}
.example-card .ex-solution{color:var(--slate-500);font-size:.88rem;line-height:1.8;margin-top:8px;padding-top:8px;border-top:1px dashed var(--slate-200)}
.example-card .ex-solution strong{color:var(--slate-700)}
.example-card .ex-answer{display:inline-block;margin-top:6px;background:var(--green-light);color:var(--green-dark);padding:2px 14px;border-radius:999px;font-weight:600;font-size:.82rem}
.expand-toggle{color:var(--blue);cursor:pointer;font-size:.85rem;font-weight:600;margin-top:4px;display:inline-block}
.expand-toggle:hover{text-decoration:underline}

.quiz-section{background:#fff;border-radius:var(--radius);border:1px solid var(--slate-200);padding:32px}
.quiz-section h3{font-size:1.3rem;font-weight:700;margin-bottom:8px}
.quiz-section .quiz-desc{color:var(--slate-500);font-size:.9rem;margin-bottom:24px}
.quiz-question{font-size:1.05rem;font-weight:600;margin-bottom:20px;color:var(--slate-700);line-height:1.8;padding:16px 20px;background:var(--slate-50);border-radius:var(--radius-sm);border:1px solid var(--slate-200)}
.quiz-question .q-meta{font-size:.8rem;color:var(--slate-400);font-weight:400;margin-bottom:8px}
.quiz-options{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.quiz-option{display:flex;align-items:center;gap:12px;padding:14px 18px;border:2px solid var(--slate-200);border-radius:var(--radius-sm);cursor:pointer;transition:all .15s;font-size:.95rem}
.quiz-option:hover{border-color:var(--blue);background:var(--blue-light)}
.quiz-option.selected{border-color:var(--blue);background:var(--blue-light)}
.quiz-option.correct{border-color:var(--green);background:var(--green-light)}
.quiz-option.wrong{border-color:var(--red);background:var(--red-light)}
.quiz-option .opt-letter{width:32px;height:32px;border-radius:50%;background:var(--slate-100);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;flex-shrink:0}
.quiz-option.selected .opt-letter{background:var(--blue);color:#fff}
.quiz-option.correct .opt-letter{background:var(--green);color:#fff}
.quiz-option.wrong .opt-letter{background:var(--red);color:#fff}
.quiz-feedback{display:none;padding:16px;border-radius:var(--radius-sm);margin-bottom:20px;font-size:.9rem;line-height:1.7}
.quiz-feedback.show{display:block}
.quiz-feedback.success{background:var(--green-light);color:var(--green-dark)}
.quiz-feedback.fail{background:var(--red-light);color:var(--red)}
.quiz-feedback .fb-steps{margin-top:8px;padding-top:8px;border-top:1px solid rgba(0,0,0,.08)}
.quiz-actions{display:flex;gap:10px;flex-wrap:wrap}
.btn{padding:10px 24px;border-radius:999px;border:none;font-size:.9rem;font-weight:600;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:6px}
.btn-primary{background:var(--blue);color:#fff}
.btn-primary:hover{background:var(--blue-dark)}
.btn-primary:disabled{background:var(--slate-300);cursor:not-allowed}
.btn-outline{background:transparent;border:2px solid var(--slate-300);color:var(--slate-600)}
.btn-outline:hover{border-color:var(--blue);color:var(--blue)}
.btn-sm{padding:6px 16px;font-size:.8rem}
.progress-section{background:#fff;border-radius:var(--radius);border:1px solid var(--slate-200);padding:32px;margin-top:32px}
.progress-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:20px;margin-bottom:28px}
.stat-card{text-align:center;padding:20px;border-radius:var(--radius-sm);background:var(--slate-50)}
.stat-card .stat-value{font-size:2rem;font-weight:800;color:var(--blue)}
.stat-card .stat-label{font-size:.85rem;color:var(--slate-500);margin-top:4px}
.progress-bar-large{height:12px;border-radius:6px;background:var(--slate-100);overflow:hidden}
.progress-bar-large .pb-fill{height:100%;background:linear-gradient(90deg,var(--blue),var(--purple));border-radius:6px;transition:width .5s ease}
.footer{text-align:center;padding:40px 24px;color:var(--slate-400);font-size:.85rem}
.back-to-top{position:fixed;bottom:24px;right:24px;width:44px;height:44px;border-radius:50%;background:var(--blue);color:#fff;border:none;cursor:pointer;font-size:1.3rem;display:none;align-items:center;justify-content:center;box-shadow:var(--shadow-md);z-index:50;transition:all .2s}
.back-to-top:hover{background:var(--blue-dark);transform:translateY(-2px)}
.back-to-top.visible{display:flex}

@media(max-width:768px){
  .hero h1{font-size:1.6rem}.hero p{font-size:.95rem}
  .topics-grid{grid-template-columns:1fr}
  .topbar{padding:0 12px}.topbar .stats-summary{display:none}
  .detail-panel{max-height:92vh;border-radius:var(--radius) var(--radius) 0 0}
  .detail-panel .dp-body{padding:0 20px 20px}.detail-panel .dp-top{padding:20px 20px 0}
  .progress-stats{grid-template-columns:repeat(2,1fr)}.grade-tabs{overflow-x:auto;flex-wrap:nowrap}
}
@media(max-width:480px){
  .hero{padding:40px 16px}.container{padding:20px 12px}
  .quiz-section,.progress-section{padding:20px}
}
</style>
</head>
<body>

<header class="topbar">
  <a href="#" class="logo"><svg viewBox="0 0 32 32" width="32" height="32"><rect width="32" height="32" rx="8" fill="#3b82f6"/><text x="16" y="23" text-anchor="middle" fill="white" font-size="18" font-weight="bold">∑</text></svg>初中数学自学</a>
  <nav>
    <a href="#topics" class="active" data-nav="topics">知识点</a>
    <a href="#quiz" data-nav="quiz">刷题</a>
    <a href="#progress" data-nav="progress">进度</a>
  </nav>
  <div class="stats-summary">掌握 <strong id="navMastered">0</strong> 个知识点</div>
</header>

<section class="hero">
  <div class="hero-inner">
    <h1>搞定初中数学，从这里开始</h1>
    <p>25 个专题 · 130+ 道典型例题 · 每题有分步解析，覆盖初一至初三全部重难点</p>
    <div class="hero-badges">
      <span class="hero-badge">📐 代数与方程</span><span class="hero-badge">📏 几何与证明</span><span class="hero-badge">📊 函数与图像</span><span class="hero-badge">🎲 概率与统计</span>
    </div>
  </div>
</section>

<main class="container">
  <section id="topics">
    <div class="section-title">📚 知识点总览 <span class="count" id="topicCount">共 25 个重难点</span></div>
    <div class="grade-tabs" id="gradeTabs">
      <button class="grade-tab active" data-grade="all">全部</button>
      <button class="grade-tab" data-grade="7">初一</button>
      <button class="grade-tab" data-grade="8">初二</button>
      <button class="grade-tab" data-grade="9">初三</button>
    </div>
    <div class="topics-grid" id="topicsGrid"></div>
  </section>

  <section id="quiz">
    <div class="section-title">🎯 针对性练习</div>
    <div class="quiz-section" id="quizArea">
      <h3>选择知识点开始刷题</h3>
      <p class="quiz-desc">每道题即时反馈，错题有分步解析</p>
      <div class="quiz-question" id="quizQuestion"><span class="q-meta">待选题</span>点击知识点卡片中的「去练习」按钮开始</div>
      <div class="quiz-options" id="quizOptions"></div>
      <div class="quiz-feedback" id="quizFeedback"></div>
      <div class="quiz-actions" id="quizActions"></div>
    </div>
  </section>

  <section id="progress">
    <div class="section-title">📈 学习进度</div>
    <div class="progress-section">
      <div class="progress-stats" id="progressStats">
        <div class="stat-card"><div class="stat-value" id="statTotal">25</div><div class="stat-label">总知识点</div></div>
        <div class="stat-card"><div class="stat-value" id="statMastered">0</div><div class="stat-label">已掌握</div></div>
        <div class="stat-card"><div class="stat-value" id="statAttempted">0</div><div class="stat-label">练习过的专题</div></div>
        <div class="stat-card"><div class="stat-value" id="statAccuracy">--</div><div class="stat-label">答题正确率</div></div>
      </div>
      <div class="progress-bar-large"><div class="pb-fill" id="progressFill" style="width:0%"></div></div>
    </div>
  </section>
</main>

<footer class="footer"><p>初中数学自学平台 · 25个专题覆盖全部重难点</p></footer>

<div class="detail-overlay" id="detailOverlay"><div class="detail-panel" id="detailPanel"></div></div>

<script>
/* ========== DATA: 25 TOPICS, 130+ QUESTIONS ========== */
const topics = [
  // ===== 初一 (7 topics) =====
  {id:"t1",grade:7,title:"有理数运算",category:"algebra",level:"basic",desc:"正负数、绝对值、数轴、四则运算与乘方——计算基本功，贯穿整个初中。",tags:["数轴","绝对值","运算律"],content:`
    <h4>📖 核心概念</h4>
    <p>有理数是能写成 <strong>a/b</strong>（a、b为整数，b≠0）的数。整数、有限小数、无限循环小数都是有理数。π 和无限不循环小数是<strong>无理数</strong>。</p>
    <div class="formula-block"><strong>绝对值：</strong>|a| = a（a≥0）；|a| = -a（a&lt;0）<br><strong>加法法则：</strong>同号相加取同号，异号相加取绝对值大的符号<br><strong>乘法法则：</strong>同号得正，异号得负</div>
    <div class="tip-block">💡 <strong>最大陷阱：</strong>-3² = -9（指数只作用于3），(-3)² = 9（括号让负号也参与平方）。考试最爱考这个！</div>
    <h4>📝 典型例题</h4>
    <div class="detail-examples">
      <div class="example-card"><div class="ex-q">例1：计算 (-2)³ + 6 ÷ (-3) - | -5 |</div><div class="ex-solution"><strong>解：</strong>(-2)³=-8；6÷(-3)=-2；|-5|=5；-8+(-2)-5=-15。<span class="ex-answer">-15</span></div></div>
      <div class="example-card"><div class="ex-q">例2：若 |a-2| + (b+3)² = 0，求 a+b</div><div class="ex-solution"><strong>解：</strong>|a-2|≥0，(b+3)²≥0，和为零则各自为0。a-2=0→a=2；b+3=0→b=-3；a+b=-1。<span class="ex-answer">-1</span></div></div>
      <div class="example-card"><div class="ex-q">例3：比较 -¾ 和 -⅔ 的大小</div><div class="ex-solution"><strong>解：</strong>|-¾|=0.75，|-⅔|≈0.667。两个负数，绝对值大的反而小，所以 -¾ &lt; -⅔。<span class="ex-answer">-¾ &lt; -⅔</span></div></div>
      <div class="example-card"><div class="ex-q">例4：计算 1÷(-⅓) + (-2)² × 0.5 - |-4|</div><div class="ex-solution"><strong>解：</strong>1÷(-⅓)=1×(-3)=-3；(-2)²×0.5=4×0.5=2；|-4|=4；-3+2-4=-5。<span class="ex-answer">-5</span></div></div>
      <div class="example-card"><div class="ex-q">例5：数轴上点A表示-3，点B表示5，求AB的长度和AB中点坐标</div><div class="ex-solution"><strong>解：</strong>AB=|5-(-3)|=|8|=8。中点=(-3+5)÷2=1。<span class="ex-answer">长度8，中点1</span></div></div>
    </div>
    <h4>🧠 为什么重要</h4>
    <p>有理数运算是整个初中数学的<strong>计算基础</strong>。后面学的方程、函数、几何计算全部依赖它。如果这里不过关，后面处处踩坑。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 负号是初一新生犯错最多的地方：-3² 和 (-3)² 的区别一定要分清。带负数的加减运算，<strong>先定符号、再算数值</strong>。</div>
    <h4>🌍 生活中的有理数</h4>
    <p>温度计上的负数（零下5°C就是 -5）、海拔高度（海平面以下）、银行账户的透支，都是负数的应用。向东走5米记作 +5，向西走3米记作 -3——正负方向让世界变得有序。</p>
  `,questions:[
    {q:"计算 (-3)² × (-2) 的结果是？",opts:["18","-18","-12","12"],ans:1,explain:"(-3)²=9，9×(-2)=-18。先乘方再乘法。"},
    {q:"|a-2|+|b+3|=0，则 a+b=？",opts:["-1","1","-5","5"],ans:0,explain:"绝对值≥0，和为0→各为0→a=2，b=-3，a+b=-1。"},
    {q:"计算 3÷(-½)+(-4)×0.5",opts:["-8","-5","-2","-6"],ans:0,explain:"3÷(-½)=3×(-2)=-6；(-4)×0.5=-2；-6+(-2)=-8。"},
    {q:"数轴上，到-1距离为4的点表示的数是？",opts:["3","-5","3或-5","3或5"],ans:2,explain:"-1+4=3，-1-4=-5。数轴上到一个点距离为定值的点有两个。"},
    {q:"下列哪个数是有理数？",opts:["π","√2","0.333...","√3"],ans:2,explain:"0.333...是无限循环小数=⅓，是有理数。π和√2、√3都是无理数。"}
  ]},
  {id:"t2",grade:7,title:"整式加减",category:"algebra",level:"basic",desc:"同类项合并、去括号、整式化简——代数运算的第一个台阶。",tags:["同类项","合并","去括号"],content:`
    <h4>📖 核心概念</h4>
    <p><strong>同类项：</strong>所含字母相同且相同字母的指数也相同的项。常数项都是同类项。合并同类项时，系数相加，字母部分不变。</p>
    <div class="formula-block"><strong>去括号法则：</strong><br>括号前是"+"：去掉括号，各项不变号<br>括号前是"-"：去掉括号，各项<strong>全部变号</strong></div>
    <div class="tip-block">💡 <strong>常见错误：</strong>-(2x-3y+1) = -2x+3y-1，常数1也要变号为-1！括号前是负号，括号内<strong>每一项</strong>都要变号，不能只变第一项。</div>
    <div class="detail-examples">
      <div class="example-card"><div class="ex-q">例1：合并同类项 3x²-2x+5-2x²+4x-1</div><div class="ex-solution"><strong>解：</strong>(3x²-2x²)+(-2x+4x)+(5-1)=x²+2x+4。<span class="ex-answer">x²+2x+4</span></div></div>
      <div class="example-card"><div class="ex-q">例2：化简 2(3a-b)-3(a+2b)+4b</div><div class="ex-solution"><strong>解：</strong>=6a-2b-3a-6b+4b=3a-4b。<span class="ex-answer">3a-4b</span></div></div>
      <div class="example-card"><div class="ex-q">例3：已知 A=2x²+3x-1，B=x²-2x+4，求 A-2B</div><div class="ex-solution"><strong>解：</strong>A-2B=(2x²+3x-1)-2(x²-2x+4)=2x²+3x-1-2x²+4x-8=7x-9。<span class="ex-answer">7x-9</span></div></div>
    </div>
    <h4>🧠 为什么重要</h4>
    <p>整式加减是<strong>代数运算的第一个台阶</strong>。合并同类项是后续因式分解、解方程、函数变形的基础操作。掌握不好的话，后续整个代数链条都受影响。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 去括号最容易错的两处：(1) 括号前是负号时，只变了第一项的符号，忘了变后面——<strong>每一项都要变号</strong>；(2) 不是同类项强行合并——3x² 和 3x 不能合并！</div>
    <h4>🌍 生活中的整式</h4>
    <p>购物找零：买3个苹果每个x元，再买2个橙子每个y元，总共花费 3x+2y ——这就是整式的实际应用。合并同类项就像把同一种水果的钱加在一起。</p>
  `,questions:[
    {q:"多项式 5a²-3a+2a²+a-7 合并后是？",opts:["7a²-2a-7","7a²-4a-7","7a²-3a-7","10a²-3a-7"],ans:0,explain:"5a²+2a²=7a²；-3a+a=-2a；常数项-7不变。结果7a²-2a-7。"},
    {q:"-(3x-2y+5) 去括号得？",opts:["-3x-2y+5","-3x+2y-5","3x-2y-5","-3x+2y+5"],ans:1,explain:"括号前是负号，每一项变号：-3x+2y-5。"},
    {q:"多项式 3(x²-y)-2(x²+y) 化简得？",opts:["x²-5y","x²+y","5x²-5y","x²-5y²"],ans:0,explain:"3x²-3y-2x²-2y=x²-5y。"},
    {q:"若 2x²ᵐy³ 与 -3x⁴yⁿ 是同类项，则 m+n=？",opts:["4","5","7","6"],ans:1,explain:"同类项要求指数相同：2m=4→m=2；n=3；m+n=5。"}
  ]},
  {id:"t3",grade:7,title:"一元一次方程",category:"algebra",level:"medium",desc:"移项、去分母、解应用题——方程思维的起点，中考应用题的重要基础。",tags:["移项","去分母","应用题","含参方程"],content:`
    <h4>📖 核心概念</h4>
    <p>形如 ax+b=0（a≠0）的方程。解方程本质是<strong>等式的基本性质</strong>：等式两边同时加减同一个数、乘除同一个非零数，等式仍成立。</p>
    <div class="formula-block"><strong>标准解法五步：</strong><br>① 去分母（最小公倍数）→ ② 去括号 → ③ 移项（变号）→ ④ 合并同类项 → ⑤ 系数化为1</div>
    <div class="tip-block">💡 <strong>应用题思路：</strong>找等量关系→设未知数→列方程→解方程→检验→作答。大部分分数丢在「找等量关系」和「检验」两步！</div>
    <div class="detail-examples">
      <div class="example-card"><div class="ex-q">例1：解 3(x-1)=2x+4</div><div class="ex-solution"><strong>解：</strong>3x-3=2x+4→3x-2x=4+3→x=7。<span class="ex-answer">x=7</span></div></div>
      <div class="example-card"><div class="ex-q">例2：解 x/2 + x/3 = 5</div><div class="ex-solution"><strong>解：</strong>两边同乘6→3x+2x=30→5x=30→x=6。<span class="ex-answer">x=6</span></div></div>
      <div class="example-card"><div class="ex-q">例3：一数加5后乘3再减7等于20，求这个数</div><div class="ex-solution"><strong>解：</strong>设该数为x→3(x+5)-7=20→3x+15-7=20→3x=12→x=4。<span class="ex-answer">4</span></div></div>
      <div class="example-card"><div class="ex-q">例4：关于x的方程 2x+a=x-3 的解为 x=2，求a</div><div class="ex-solution"><strong>解：</strong>代入x=2→4+a=2-3→4+a=-1→a=-5。<span class="ex-answer">a=-5</span></div></div>
      <div class="example-card"><div class="ex-q">例5：甲骑车速度15km/h，乙步行速度5km/h，甲先出发30分钟后乙出发，问乙出发几小时后甲追上乙？</div><div class="ex-solution"><strong>解：</strong>甲提前30分钟走了7.5km。设乙出发x小时后追上→15x=5x+7.5→10x=7.5→x=0.75。<span class="ex-answer">0.75小时（45分钟）</span></div></div>
    </div>
    <h4>🧠 为什么重要</h4>
    <p>一元一次方程是<strong>方程思维的起点</strong>，也是中考应用题的重要基础。几乎所有"已知……求……"的问题都可以用列方程解决。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 移项最常见的错是<strong>忘了变号</strong>。比如 3x+2=5x-1，移项后应该是 3x-5x=-1-2（不是 +2！）。每个移到等号另一边的项都必须变号。</div>
    <h4>🌍 生活中的方程</h4>
    <p>买了3支笔找回7元，给了50元——设笔价为x：3x+7=50 → x≈14.3元。路程问题中，速度×时间=路程公式本身就是最经典的方程模型。</p>
  `,questions:[
    {q:"解方程 4x-3=5x+2",opts:["x=5","x=-5","x=1","x=-1"],ans:1,explain:"4x-3=5x+2→4x-5x=2+3→-x=5→x=-5。"},
    {q:"方程 (x+1)/3-(x-2)/6=1 的解是？",opts:["x=2","x=3","x=4","x=6"],ans:0,explain:"两边×6→2(x+1)-(x-2)=6→2x+2-x+2=6→x+4=6→x=2。"},
    {q:"方程 2x+3a=5 的解为 x=-1，则a=？",opts:["1","7/3","-1","-7/3"],ans:1,explain:"代入x=-1→-2+3a=5→3a=7→a=7/3。"},
    {q:"小明买3支笔和2个本子花11元，买2支笔和3个本子花12元，一支笔多少钱？",opts:["1元","1.8元","2元","2.2元"],ans:1,explain:"设笔x元本y元：3x+2y=11，2x+3y=12→两式相加→5x+5y=23→x+y=4.6；相减→x-y=-1→x=1.8。"}
  ]},
  {id:"t4",grade:7,title:"二元一次方程组",category:"algebra",level:"medium",desc:"代入消元、加减消元——两未知数问题从此有系统解法。",tags:["代入消元","加减消元","应用题"],content:`
    <h4>📖 核心概念</h4>
    <p>两个未知数、两个方程组成的方程组。解是同时满足两个方程的 (x,y) 值对。</p>
    <div class="formula-block"><strong>两种解法：</strong><br><strong>代入法：</strong>从一个方程解出一个未知数→代入另一个方程<br><strong>加减法：</strong>使同一个未知数的系数相等或互为相反数→加减消元</div>
    <div class="tip-block">💡 <strong>选择策略：</strong>某个未知数系数为1或-1时用代入法；两个方程中同未知数系数成倍数关系时用加减法。应用题先理清"两个等量关系"再列方程。</div>
    <div class="detail-examples">
      <div class="example-card"><div class="ex-q">例1：解 { x+y=5，2x-y=4 }</div><div class="ex-solution"><strong>解：</strong>两式相加消y→3x=9→x=3；代入x+y=5→y=2。<span class="ex-answer">x=3，y=2</span></div></div>
      <div class="example-card"><div class="ex-q">例2：解 { 2x+3y=7，3x-2y=4 }（两个未知数系数都不为1）</div><div class="ex-solution"><strong>解：</strong>①×2→4x+6y=14；②×3→9x-6y=12；相加→13x=26→x=2；代入①→4+3y=7→y=1。<span class="ex-answer">x=2，y=1</span></div></div>
      <div class="example-card"><div class="ex-q">例3：鸡兔同笼——头30个、脚84只，鸡兔各几只？</div><div class="ex-solution"><strong>解：</strong>设鸡x只兔y只→x+y=30，2x+4y=84→②÷2得x+2y=42→减①→y=12→x=18。<span class="ex-answer">鸡18只，兔12只</span></div></div>
    </div>
    <h4>🧠 为什么重要</h4>
    <p>二元一次方程组解决的是<strong>两个未知量的关联问题</strong>。从"鸡兔同笼"到"两种商品混合"，生活中有大量双变量问题。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 加减消元时，方程两边要<strong>同时乘</strong>，不能只乘一边。② 代入消元时，代入后要仔细检查括号——代入式子本就含负号时很容易出错。</div>
    <h4>🌍 生活中的方程组</h4>
    <p>买3瓶可乐+2包薯片=25元，买2瓶可乐+3包薯片=27元——两种商品单价是多少？这就是典型的二元一次方程组问题。</p>
  `,questions:[
    {q:"方程组 {x+y=7，x-y=1} 的解是？",opts:["(4,3)","(3,4)","(5,2)","(2,5)"],ans:0,explain:"两式相加→2x=8→x=4，代入→y=3。"},
    {q:"方程组 {3x-y=8，x+2y=5} 的解是？",opts:["x=3,y=1","x=2,y=-2","x=1,y=-5","x=4,y=4"],ans:0,explain:"由①→y=3x-8代入②→x+2(3x-8)=5→7x=21→x=3→y=1。"}
  ]},
  {id:"t5",grade:7,title:"一元一次不等式",category:"algebra",level:"medium",desc:"解不等式与方程类似，但乘除负数时不等号要反转——这是核心区别。",tags:["解集","数轴","不等号反转"],content:`
    <h4>📖 核心概念</h4>
    <p>等号换成不等号（&gt;、&lt;、≥、≤）就是不等式。解集是满足不等式的所有值，可以画在数轴上（实心圆=包含端点，空心圆=不包含）。</p>
    <div class="formula-block"><strong>两条核心规则：</strong><br>① 两边加减同一数：不等号<strong>不变</strong><br>② 两边乘除同一<strong>正数</strong>：不等号<strong>不变</strong><br>③ 两边乘除同一<strong>负数</strong>：不等号<strong>反转</strong></div>
    <div class="tip-block">💡 规则③是不等式与方程唯一本质区别。如 -2x&gt;6，两边除以-2，不等号反转→x&lt;-3。</div>
    <h4>🧠 为什么重要</h4>
    <p>不等式是方程的自然延伸，但不等号反转是<strong>独有的考点</strong>。生活中的"至少""不超过""大于"等条件都需要不等式来描述。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 <strong>最大坑：乘除负数不等号反转。</strong>这是不等式与方程<strong>唯一的本质区别</strong>。忘记反转=错一半分。</div>
    <h4>🌍 生活中的不等式</h4>
    <p>购物券满100减20，你选了几件商品总价x元——x>100时才能用券，x≥100也行吗？这取决于商家规则。打折优惠的本质就是不等式条件。</p>
  `,questions:[
    {q:"解不等式 -2x > 6",opts:["x > -3","x < -3","x > 3","x < 3"],ans:1,explain:"除以-2，不等号反转：x &lt; -3。"},
    {q:"3x+1 ≤ 2x+5 的解是？",opts:["x ≤ 4","x ≤ -4","x ≥ 4","x < 4"],ans:0,explain:"3x-2x ≤ 5-1→x ≤ 4。"},
    {q:"不等式 2(x-1) > 3x-5 的解集是？",opts:["x < 3","x > 3","x < -3","x > -3"],ans:0,explain:"2x-2>3x-5→2x-3x>-5+2→-x>-3→x&lt;3（除以-1反转！）。"}
  ]},
  {id:"t6",grade:7,title:"平面直角坐标系",category:"geometry",level:"basic",desc:"坐标、象限、对称、平移与距离——代数和几何在这里交汇。",tags:["象限","对称","距离","平移"],content:`
    <h4>📖 核心概念</h4>
    <p>x轴（横轴）和y轴（纵轴）垂直相交于原点O(0,0)。点P(x,y)中x为横坐标，y为纵坐标。</p>
    <div class="formula-block"><strong>四个象限：</strong>Ⅰ(+,+)·Ⅱ(-,+)·Ⅲ(-,-)·Ⅳ(+,-)<br><strong>对称：</strong>关于x轴(x,-y)·关于y轴(-x,y)·关于原点(-x,-y)<br><strong>距离：</strong>P到原点=√(x²+y²)；P₁P₂=√[(x₁-x₂)²+(y₁-y₂)²]</div>
    <div class="tip-block">💡 关于谁对称谁不变（符号不变），另外的坐标变号。如关于x轴对称→x不变，y变号。</div>
    <h4>🧠 为什么重要</h4>
    <p>坐标系是<strong>数形结合的基石</strong>。后面的一次函数图像、二次函数图像、几何图形的坐标表示全依赖它。它是代数和几何的桥梁。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 记错象限的正负号是第一大坑。口诀："一全正，二正弦，三正切，四余弦"只适用于三角函数，<strong>点坐标的口诀是(x,y)→第一(+,+) 第二(-,+) 第三(-,-) 第四(+,-)</strong>。</div>
    <h4>🌍 生活中的坐标系</h4>
    <p>电影院座位是天然的坐标系——第几排=纵坐标，第几座=横坐标。手机地图上的经纬度定位本质上也是坐标。围棋棋盘、Excel表格都是坐标系的现实应用。</p>
  `,questions:[
    {q:"点P(-3,4)在第几象限？",opts:["第一","第二","第三","第四"],ans:1,explain:"x&lt;0,y&gt;0，属于第二象限。"},
    {q:"点A(2,-5)关于原点对称的坐标是？",opts:["(2,5)","(-2,-5)","(-2,5)","(5,-2)"],ans:2,explain:"关于原点对称x和y都变号→(-2,5)。"},
    {q:"点(3,-4)到x轴的距离是？",opts:["3","4","5","7"],ans:1,explain:"点到x轴距离=|纵坐标|=|-4|=4。"}
  ]},
  {id:"t7",grade:7,title:"平行线与相交线",category:"geometry",level:"basic",desc:"对顶角、同位角、内错角、同旁内角——几何推理的起点。",tags:["对顶角","同位角","平行判定"],content:`
    <h4>📖 核心概念</h4>
    <p>两条直线相交形成四个角——对顶角相等、邻补角互补(和为180°)。两条直线被第三条所截产生8个角——同位角、内错角、同旁内角。</p>
    <div class="formula-block"><strong>平行线判定（三选一即可）：</strong><br>① 同位角相等 → 平行<br>② 内错角相等 → 平行<br>③ 同旁内角互补 → 平行</div>
    <div class="tip-block">💡 证平行就是找角的关系——先用对顶角、邻补角做桥梁，再套判定定理。</div>
    <h4>🧠 为什么重要</h4>
    <p>平行线是<strong>几何推理的起点</strong>。后面证明三角形全等、平行四边形、相似，都离不开角的关系推理。同位角/内错角/同旁内角是几何语言的ABC。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 同位角和内错角容易混淆——把图转90°或者换一条截线就容易认错。<strong>技巧：先在图中找到"F型"=同位角，"Z型"=内错角，"U型"=同旁内角。</strong></div>
    <h4>🌍 生活中的平行线</h4>
    <p>铁轨的两条钢轨永远平行。斑马线、楼梯扶手、书架的隔板——生活中处处是平行线的应用。判断两条路是否平行，本质上就是在用量角器量同位角。</p>
  `,questions:[
    {q:"AB∥CD，∠1=70°，∠1的同位角=？",opts:["70°","110°","20°","无法确定"],ans:0,explain:"两直线平行，同位角相等。"},
    {q:"两直线被第三条所截，内错角相等则两直线？",opts:["相交","平行","垂直","不确定"],ans:1,explain:"内错角相等→两直线平行，是判定定理。"},
    {q:"若两直线平行，同旁内角和=？",opts:["90°","180°","360°","不确定"],ans:1,explain:"两直线平行→同旁内角互补→和为180°。"}
  ]},

  // ===== 初二 (9 topics) =====
  {id:"t8",grade:8,title:"整式乘法与因式分解",category:"algebra",level:"medium",desc:"平方差、完全平方、十字相乘——代数运算最核心的工具包。",tags:["平方差","完全平方","十字相乘","分组分解"],content:`
    <h4>📖 核心公式</h4>
    <div class="formula-block"><strong>平方差：</strong>a²-b²=(a+b)(a-b)<br><strong>完全平方：</strong>(a±b)²=a²±2ab+b²<br><strong>十字相乘：</strong>x²+(p+q)x+pq=(x+p)(x+q)</div>
    <h4>🔑 因式分解步骤</h4>
    <ol class="dp-steps"><li>先提公因式</li><li>两项看平方差，三项看完全平方或十字相乘，四项考虑分组</li><li>分解到底——每个因式不能再分解</li></ol>
    <div class="tip-block">💡 一提（公因式）二套（公式）三检查。忘记提公因式是最常见的丢分原因！</div>
    <div class="detail-examples">
      <div class="example-card"><div class="ex-q">例1：分解 x²-9y²</div><div class="ex-solution"><strong>解：</strong>平方差→x²-(3y)²=(x+3y)(x-3y)。<span class="ex-answer">(x+3y)(x-3y)</span></div></div>
      <div class="example-card"><div class="ex-q">例2：分解 x²+5x+6</div><div class="ex-solution"><strong>解：</strong>和为5积为6→2和3→(x+2)(x+3)。<span class="ex-answer">(x+2)(x+3)</span></div></div>
      <div class="example-card"><div class="ex-q">例3：分解 2x²+7x+3</div><div class="ex-solution"><strong>解：</strong>a≠1的十字相乘→2×3=6，找两个数积为6和为7→1和6→2x²+x+6x+3=(2x+1)(x+3)。<span class="ex-answer">(2x+1)(x+3)</span></div></div>
      <div class="example-card"><div class="ex-q">例4：分解 x⁴-y⁴</div><div class="ex-solution"><strong>解：</strong>平方差两次→(x²)²-(y²)²=(x²+y²)(x²-y²)=(x²+y²)(x+y)(x-y)。<span class="ex-answer">(x²+y²)(x+y)(x-y)</span></div></div>
    </div>
    <h4>🧠 为什么重要</h4>
    <p>因式分解是<strong>代数运算最重要的工具包</strong>。解方程、约分、求最值、函数变形全离不开它。中考代数大题几乎必考。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 第一大错误：<strong>忘记先提公因式</strong>。比如 2x²-2，直接当平方差是错的——先提2→2(x²-1)=2(x+1)(x-1)，这才完整。第二大错误：二次三项式乱套公式。不是所有三项式都是完全平方！</div>
    <h4>🌍 生活中的因式分解</h4>
    <p>把一个大数分解质因数跟因式分解是同样的思路。比如 1024=2¹⁰ 就类似 x¹⁰ 的分解。超市把商品按品牌+种类分组陈列，也是一种"因式分解"。</p>
  `,questions:[
    {q:"x²-9y² 因式分解为？",opts:["(x-3y)²","(x+3y)(x-3y)","(x-9y)(x+y)","(x+9y)(x-y)"],ans:1,explain:"平方差公式：x²-(3y)²=(x+3y)(x-3y)。"},
    {q:"x²+5x+6 因式分解为？",opts:["(x+2)(x+3)","(x-2)(x-3)","(x+1)(x+6)","(x-1)(x+6)"],ans:0,explain:"十字相乘→和5积6→2和3→(x+2)(x+3)。"},
    {q:"计算 101²-99²，用公式最简便",opts:["400","200","40","20"],ans:0,explain:"(101+99)(101-99)=200×2=400。平方差公式在数值计算中很快。"},
    {q:"a²+6a+9 因式分解为？",opts:["(a+3)²","(a-3)²","(a+9)(a+1)","(a+4.5)²"],ans:0,explain:"完全平方公式→a²+2·a·3+3²=(a+3)²。"},
    {q:"分解 3x²-12",opts:["3(x²-4)","3(x+2)(x-2)","(3x+6)(x-2)","3(x-2)²"],ans:1,explain:"先提公因式3→3(x²-4)=3(x+2)(x-2)。"}
  ]},
  {id:"t9",grade:8,title:"分式",category:"algebra",level:"medium",desc:"分式有意义条件、运算与方程——增根检验是必考点也是丢分大户。",tags:["分母不为零","增根","通分","分式方程"],content:`
    <h4>📖 核心概念</h4>
    <p>分式有意义⇔分母≠0。分式值为0⇔分子=0且分母≠0。<strong>分式方程必须检验增根！</strong></p>
    <div class="formula-block"><strong>运算：</strong>a/b+c/d=(ad+bc)/bd；a/b×c/d=ac/bd；a/b÷c/d=a/b×d/c<br><strong>方程解法：</strong>去分母（两边乘最简公分母）→解整式方程→检验（舍去使分母为零的根）</div>
    <div class="tip-block">💡 <strong>增根来源：</strong>去分母时两边乘了一个含未知数的式子，新方程的根可能使这个式子为零——这样的根就是增根，必须舍去！</div>
    <h4>🧠 为什么重要</h4>
    <p>分式方程是<strong>增根概念的诞生地</strong>——这个概念会伴随你到高中甚至大学数学。理解增根，就能理解为什么数学证明中需要"检验"这个环节。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 <strong>解分式方程不检验=白做。</strong>约掉含未知数的分母后，得到的新方程可能会"制造"出使原方程无意义的值。每一道分式方程都必须把解代回原方程检查分母！</div>
    <h4>🌍 生活中的分式</h4>
    <p>平均速度=总路程÷总时间——这就是一个分式。斜坡的坡度=垂直高度÷水平距离。浓度=溶质÷溶液——化学实验中的配比问题本质上也是分式。</p>
  `,questions:[
    {q:"分式 (x-2)/(x+3) 何时无意义？",opts:["x=2","x=-3","x=3","x=-2"],ans:1,explain:"分母=0时分式无意义→x+3=0→x=-3。"},
    {q:"(x²-4)/(x+2) 何时值为0？",opts:["x=2","x=-2","x=±2","x=2且≠-2"],ans:3,explain:"分子=0→x=±2，但分母≠0→x≠-2→所以只有x=2。"},
    {q:"解 1/(x-2)=2/(x+1)，得x=5，检验？",opts:["是解","增根","x=5时分母为零","需再检验"],ans:0,explain:"x=5时分母都不为0，且1/3=2/6=1/3成立，是解。"},
    {q:"化简 (x²-1)/(x-1)（x≠1）",opts:["x-1","x+1","x²-1","x"],ans:1,explain:"x²-1=(x+1)(x-1)，约去x-1（因为x≠1）→x+1。"}
  ]},
  {id:"t10",grade:8,title:"二次根式",category:"algebra",level:"medium",desc:"√a 的定义域、化简与运算——从有理数到实数的关键一步。",tags:["定义域","化简","分母有理化"],content:`
    <h4>📖 核心概念</h4>
    <p>√a 有意义⇔a≥0。√(a²)=|a|（注意绝对值！）。最简二次根式：被开方数不含分母且不含能开得尽方的因数。</p>
    <div class="formula-block"><strong>运算性质：</strong><br>√a·√b=√(ab)（a,b≥0）<br>√a/√b=√(a/b)（a≥0,b&gt;0）<br>√(a²)=|a|</div>
    <div class="tip-block">💡 <strong>√(a²)=|a|！</strong>比如 √((-3)²)=|-3|=3，不是-3。这个绝对值经常被忽略。</div>
    <h4>🧠 为什么重要</h4>
    <p>二次根式把数的范围从有理数<strong>扩展到了实数</strong>。√2、√3、π这些无理数的存在，正是二次根式要处理的。勾股定理的斜边计算几乎每次都产生根式。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 √(a²)=|a| 不是 a！无论 a 是正还是负，√(a²) 的结果都是非负数。比如 √((-3)²)=3，不是 -3。这个绝对值是<strong>最高频的扣分点</strong>。</div>
    <h4>🌍 生活中的根式</h4>
    <p>正方形的对角线长=边长×√2。一块1米×1米的地砖，对角线约1.414米——你每天都在和一个无理数打交道！A4纸的长宽比就是√2:1。</p>
  `,questions:[
    {q:"√(x-3) 有意义，则x的取值范围是？",opts:["x≥3","x>3","x≠3","任意实数"],ans:0,explain:"被开方数≥0→x-3≥0→x≥3。"},
    {q:"化简 √12 = ？",opts:["2√3","3√2","√12","6"],ans:0,explain:"√12=√(4×3)=√4·√3=2√3。"},
    {q:"化简 √(a²)（a为任意实数）=？",opts:["a","-a","|a|","a²"],ans:2,explain:"√(a²)=|a|，不管a正负，结果都是非负的。"},
    {q:"分母有理化：1/√2 =？",opts:["√2","√2/2","-√2","2√2"],ans:1,explain:"分子分母同乘√2→√2/(√2·√2)=√2/2。"}
  ]},
  {id:"t11",grade:8,title:"全等三角形",category:"geometry",level:"hard",desc:"SSS、SAS、ASA、AAS、HL——初中几何证明的第一个分水岭。",tags:["SSS","SAS","ASA","HL","辅助线"],content:`
    <h4>📖 五种判定方法</h4>
    <div class="formula-block">SSS：三边对应相等 · SAS：两边及其夹角对应相等 · ASA：两角及夹边对应相等<br>AAS：两角及一角对边对应相等 · HL：斜边和一直角边对应相等（仅Rt△）</div>
    <h4>🔑 证明步骤</h4>
    <ol class="dp-steps"><li>标已知条件</li><li>找隐藏条件（公共边、公共角、对顶角）</li><li>确定判定方法</li><li>按格式写出证明</li></ol>
    <div class="tip-block">💡 SSA不能判定全等！"边边角"不是判定定理。另外证明格式要写"在△ABC和△DEF中……∴△ABC≌△DEF(判定方法)"。</div>
    <h4>🧠 为什么重要</h4>
    <p>全等三角形是<strong>初中几何证明的第一道分水岭</strong>。多数学生对几何的畏难情绪就来源于此。但一旦搞懂，后续所有几何证明都是同一套思维。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 <strong>SSA不是判定定理！</strong>千万不要用"两条边+一个角"来判定全等——除非那个角是两边的夹角(SAS)。另外证明格式要规范："在△ABC和△DEF中……∴△ABC≌△DEF(判定方法)"。</div>
    <h4>🌍 生活中的全等</h4>
    <p>两把钥匙开同一把锁——钥匙的形状就是"全等"。工厂流水线批量生产的零件，每个都必须是"全等"的。要做两个一模一样的三角形装饰板，需要测量哪几个数据？用全等判定就能算出来。</p>
  `,questions:[
    {q:"两边和一角对应相等的两三角形一定全等吗？",opts:["一定","SSA不行","SSS可以","不用判定"],ans:1,explain:"如果给的角不是夹角（SSA），不能判定全等。"},
    {q:"Rt△除了HL，还能用哪些判定？",opts:["只能用HL","四种通用都行","只能用SAS","只能用AAS"],ans:1,explain:"HL是Rt△特有，但SSS/SAS/ASA/AAS对直角三角形同样适用。"},
    {q:"要证明两条线段相等，常见思路是？",opts:["直接量","证明包含它们的三角形全等","设方程","画图估算"],ans:1,explain:"证线段相等最常见的套路→证明它们所在的两个三角形全等→对应边相等。"}
  ]},
  {id:"t12",grade:8,title:"轴对称与等腰三角形",category:"geometry",level:"medium",desc:"垂直平分线、等腰三角形、最短路径——几何中的对称美学。",tags:["垂直平分线","等腰三角形","将军饮马"],content:`
    <h4>📖 核心定理</h4>
    <div class="formula-block"><strong>等腰三角形三线合一：</strong>顶角平分线、底边中线、底边高线是同一条<br><strong>垂直平分线性质：</strong>线段垂直平分线上的点到两端距离相等<br><strong>将军饮马：</strong>直线上找一点使PA+PB最小→作对称点→连直线</div>
    <h4>🧠 为什么重要</h4>
    <p>等腰三角形的"三线合一"是几何中<strong>最优雅的性质之一</strong>。它不仅简化了大量证明，还是将军饮马等经典最值问题的理论基础。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 三线合一<strong>只在等腰三角形中成立</strong>，一般三角形没有这个性质。另外"等边三角形的三线合一在三边上都成立"——等边三角形是特殊的等腰三角形，每条边都满足。</div>
    <h4>🌍 生活中的对称</h4>
    <p>蝴蝶的翅膀、故宫的中轴线、人的左右脸——对称是大自然最偏爱的设计。轴对称给了我们"翻折"的思路，而这个思路解决了一类经典的"将军饮马"最短路径问题。</p>
  `,questions:[
    {q:"等腰三角形顶角为50°，底角=？",opts:["65°","50°","80°","130°"],ans:0,explain:"底角=(180°-50°)÷2=65°。"},
    {q:"等腰三角形中，以下哪条线一定也是高线？",opts:["底边中线","腰的中线","所有中线","角平分线"],ans:0,explain:"等腰三角形三线合一→底边中线也是高线和顶角平分线。"},
    {q:"点P在线段AB的垂直平分线上，则？",opts:["PA>PB","PA&lt;PB","PA=PB","PA+PB=AB"],ans:2,explain:"垂直平分线性质→到两端距离相等→PA=PB。"}
  ]},
  {id:"t13",grade:8,title:"勾股定理",category:"geometry",level:"hard",desc:"a²+b²=c²——平面几何最美的定理，中考必考。立体几何也离不开它。",tags:["勾股定理","逆定理","最短路径","折叠"],content:`
    <h4>📖 核心定理</h4>
    <div class="formula-block"><strong>勾股定理：</strong>Rt△中 a²+b²=c²（c为斜边）<br><strong>逆定理：</strong>若三边满足 a²+b²=c²，则为Rt△<br><strong>常见勾股数：</strong>(3,4,5)(5,12,13)(7,24,25)(8,15,17)及其倍数</div>
    <div class="tip-block">💡 <strong>应用三部曲：</strong>① 找直角三角形 ② 明确谁是斜边 ③ 列方程。折叠和最短路径问题是勾股定理的综合应用——把立体展开为平面再套勾股！</div>
    <div class="detail-examples">
      <div class="example-card"><div class="ex-q">例1：直角边6和8，求斜边</div><div class="ex-solution"><strong>解：</strong>c²=36+64=100→c=10。<span class="ex-answer">10</span></div></div>
      <div class="example-card"><div class="ex-q">例2：长方形长8宽6，求对角线长</div><div class="ex-solution"><strong>解：</strong>对角线是Rt△的斜边→d²=8²+6²=100→d=10。<span class="ex-answer">10</span></div></div>
    </div>
    <h4>🧠 为什么重要</h4>
    <p>勾股定理是<strong>平面几何最美的定理</strong>，也是中考必考。更重要的是，它是通往三角函数、解析几何乃至大学微积分的桥梁。立体几何也离不开它。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 识别谁才是斜边——斜边永远是<strong>最长</strong>的那条边，且<strong>对着直角</strong>。② 验算时注意：a²+b² 可能不等于 c² 因为计算精度——比如 √8 的平方是 8，不是 8.0001。</div>
    <h4>🌍 生活中的勾股定理</h4>
    <p>盖房子时工人拉对角线检查墙角是否90°——绳长3m、4m、5m的三角形，直角必然精确。飞机从A飞到B的最短路径也是直线上，但计算两点距离就需要勾股定理。</p>
  `,questions:[
    {q:"Rt△两直角边为6和8，斜边=？",opts:["10","14","100","2√7"],ans:0,explain:"6²+8²=36+64=100，斜边=√100=10。这组是(3,4,5)的2倍。"},
    {q:"三边5,12,13的三角形是什么类型？",opts:["锐角","直角","钝角","不确定"],ans:1,explain:"5²+12²=169=13²，逆定理判定为直角三角形。"},
    {q:"一个等腰Rt△的斜边长为√8，则直角边=？",opts:["2","√2","4","√3"],ans:0,explain:"设直角边=x→x²+x²=8→2x²=8→x=2。"}
  ]},
  {id:"t14",grade:8,title:"平行四边形",category:"geometry",level:"medium",desc:"平行四边形→矩形→菱形→正方形——四边形「进化链条」一网打尽。",tags:["对角线","矩形","菱形","正方形"],content:`
    <h4>📖 平行四边形性质与判定</h4>
    <div class="formula-block"><strong>性质：</strong>对边平行且相等、对角相等、对角线互相平分<br><strong>判定：</strong>① 两组对边平行 ② 两组对边相等 ③ 一组对边平行且相等 ④ 对角线互相平分<br>(满足其一即可)</div>
    <div class="tip-block">💡 <strong>进化链条：</strong>平行四边形+一角90°→矩形；平行四边形+邻边相等→菱形；矩形+邻边相等→正方形。证明题先证平行四边形再追加条件。</div>
    <h4>🧠 为什么重要</h4>
    <p>平行四边形是<strong>四边形的核心</strong>——矩形、菱形、正方形都是它的特例。掌握平行四边形性质后，其他特殊四边形的证明就是"追加条件即可"。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 矩形和菱形的判定必须<strong>先证平行四边形</strong>再追加条件，不能一步到位。② 对角线相等的不止矩形——等腰梯形的对角线也相等！不能看到对角线相等就直接判矩形。</div>
    <h4>🌍 生活中的平行四边形</h4>
    <p>升降晾衣架的交叉结构就是平行四边形——因为对角线互相平分，所以能保持平衡。推拉门、折叠梯、台灯的伸缩臂，都是平行四边形结构的应用。</p>
  `,questions:[
    {q:"对角线互相平分的四边形一定是？",opts:["矩形","菱形","平行四边形","正方形"],ans:2,explain:"对角线互相平分是平行四边形判定之一，不保证是特殊四边形。"},
    {q:"既是矩形又是菱形的四边形是？",opts:["平行四边形","梯形","正方形","不确定"],ans:2,explain:"正方形同时满足四直角（矩形）+四边相等（菱形）。"},
    {q:"矩形对角线=5cm，则两条对角线和=？",opts:["10cm","5cm","25cm","2.5cm"],ans:0,explain:"矩形两条对角线相等→每条5cm→和=10cm。"}
  ]},
  {id:"t15",grade:8,title:"一次函数",category:"func",level:"medium",desc:"y=kx+b——理解斜率和截距的几何意义，函数思维的真正起点。",tags:["斜率","截距","图像","待定系数法"],content:`
    <h4>📖 核心概念</h4>
    <div class="formula-block">y=kx+b：k是斜率（k&gt;0上升，k&lt;0下降，|k|越大越陡），b是y轴截距<br>图像：一条直线，过点(0,b)和(-b/k,0)<br>平移：上加下减（y→y±m），左加右减（x→x∓n）</div>
    <div class="tip-block">💡 <strong>待定系数法求解析式：</strong>已知两点→代入y=kx+b解方程组。已知与某直线平行→k相同；与某直线垂直→k₁·k₂=-1（高中才学，但初中涉及图象性质）。</div>
    <h4>🧠 为什么重要</h4>
    <p>一次函数是<strong>函数思维的真正起点</strong>。从"一个数"到"两个量之间的关系"，这是思维方式的质变。掌握了 k 和 b 的意义，后续所有函数都是一个模式。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 把 k 的正负和升降方向记反——k>0 上升（像上坡），k<0 下降（像下坡）。② 平移口诀：上加下减（对y操作），左加右减（对x操作）。左右平移最容易搞反。</div>
    <h4>🌍 生活中的一次函数</h4>
    <p>出租车计价——起步价b元+每公里k元：总价 y=kx+b。手机话费——月租b元+每分钟k元。水费阶梯计价也近似一次函数。弹簧的长度=原长+系数×挂重——这是物理学中的一次函数。</p>
  `,questions:[
    {q:"y=-2x+3 不经过哪个象限？",opts:["第一","第二","第三","第四"],ans:2,explain:"k&lt;0下降，b=3&gt;0截距正→过一、二、四象限，不过三。"},
    {q:"y=3x向上平移2个单位得？",opts:["y=3x+2","y=3x-2","y=3(x+2)","y=5x"],ans:0,explain:"上加下减→y=3x+2。"},
    {q:"直线过(0,-3)和(2,1)，解析式是？",opts:["y=2x-3","y=x-3","y=2x+3","y=x+3"],ans:0,explain:"代入y=kx+b→b=-3；1=2k-3→k=2→y=2x-3。"}
  ]},
  {id:"t16",grade:8,title:"数据的分析",category:"stats",level:"basic",desc:"平均数、中位数、众数、方差——数据时代的基本功。",tags:["平均数","中位数","方差","加权"],content:`
    <h4>📖 核心概念</h4>
    <div class="formula-block"><strong>平均数：</strong>x̄=Σxᵢ/n<br><strong>加权平均数：</strong>x̄=(w₁x₁+…+wₙxₙ)/(w₁+…+wₙ)<br><strong>方差：</strong>s²=Σ(xᵢ-x̄)²/n，衡量波动程度<br><strong>中位数：</strong>排序后正中间的数</div>
    <div class="tip-block">💡 有极端值用中位数（不受极端值影响）；数据均匀用平均数；分类数据用众数；方差越小越稳定。</div>
    <h4>🧠 为什么重要</h4>
    <p>数据分析是<strong>信息时代的核心素养</strong>。看懂平均数、中位数、方差，就能看懂各类统计报告——从考试成绩分析到疫情数据解读。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 平均数vs中位数选错了代表值——比如一个班有一个人考了满分100，其他人全在60-70之间，用平均数会被满分拉高，用中位数才是真实水平。有极端值时，<strong>中位数比平均数可靠</strong>。</div>
    <h4>🌍 生活中的统计</h4>
    <p>你的考试成绩出来后，全班平均分告诉你"整体水平"，中位数告诉你"中等水平"，方差告诉你"大家差距大不大"。三种数据结合，才能全面了解自己的位置。</p>
  `,questions:[
    {q:"数据2,3,3,4,5,6,7的中位数是？",opts:["3","4","3.5","4.5"],ans:1,explain:"7个数，第4个是4（排序后的中间位置）。"},
    {q:"两组数据均值相同，比较稳定性看？",opts:["中位数","众数","方差","最大值"],ans:2,explain:"方差反映波动→方差越小数据越集中。"}
  ]},

  // ===== 初三 (9 topics) =====
  {id:"t17",grade:9,title:"一元二次方程",category:"algebra",level:"hard",desc:"求根公式、判别式、韦达定理——代数最高频综合考点，中考必出大题。",tags:["求根公式","判别式","韦达定理","配方法"],content:`
    <h4>📖 核心公式</h4>
    <div class="formula-block">ax²+bx+c=0（a≠0）<br><strong>求根公式：</strong>x=[-b±√(b²-4ac)]/(2a)<br><strong>判别式：</strong>Δ=b²-4ac→Δ&gt;0两不等实根·Δ=0两相等实根·Δ&lt;0无实根<br><strong>韦达定理：</strong>x₁+x₂=-b/a，x₁x₂=c/a</div>
    <div class="tip-block">💡 <strong>三大解法选择：</strong>能十字相乘直接拆（最快），不行用求根公式（万能），配方只用于求顶点等特定场景。韦达定理不直接解方程也能得两根之和与积。</div>
    <div class="detail-examples">
      <div class="example-card"><div class="ex-q">例1：解 x²-5x+6=0</div><div class="ex-solution"><strong>解：</strong>(x-2)(x-3)=0→x=2或x=3。<span class="ex-answer">x₁=2，x₂=3</span></div></div>
      <div class="example-card"><div class="ex-q">例2：x²-2x-1=0（无法十字相乘）</div><div class="ex-solution"><strong>解：</strong>求根公式→x=[2±√(4+4)]/2=[2±√8]/2=1±√2。<span class="ex-answer">x=1±√2</span></div></div>
      <div class="example-card"><div class="ex-q">例3：若方程 x²-mx+6=0 有两根且x₁=x₂，求m</div><div class="ex-solution"><strong>解：</strong>等根→Δ=0→m²-24=0→m=±2√6。<span class="ex-answer">m=±2√6</span></div></div>
    </div>
    <h4>🧠 为什么重要</h4>
    <p>一元二次方程是<strong>中考代数的大轴考点</strong>，也是高中数学的基石。抛物线、最值问题、增长率问题——这些都是二次方程的天下。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 求根公式中分母是 2a，老有人记成 2 或 a，漏掉系数。② 韦达定理只适用于<strong>标准形式</strong> ax²+bx+c=0——如果方程有系数不是1，先标准化再套公式。</div>
    <h4>🌍 生活中的二次方程</h4>
    <p>投篮的抛物线轨迹可以用二次函数描述。计算"多少年后存款翻倍"的复利问题本质上是一元二次方程。手机信号的衰减曲线、桥梁的拱形结构都是二次方程的几何表达。</p>
  `,questions:[
    {q:"x²-5x+6=0的两根是？",opts:["2和3","1和6","-2和-3","2和-3"],ans:0,explain:"十字相乘→(x-2)(x-3)=0→x=2或3。"},
    {q:"若x²+mx+9=0有等根，则m=？",opts:["±3","±6","±9","6"],ans:1,explain:"Δ=0→m²-36=0→m=±6。"},
    {q:"x²-3x+1=0的两根之和=？",opts:["-3","3","1","-1"],ans:1,explain:"韦达定理→x₁+x₂=-(-3)/1=3。"},
    {q:"x²-4x+1=0的两根之积=？",opts:["-4","4","1","-1"],ans:2,explain:"韦达定理→x₁x₂=c/a=1/1=1。"},
    {q:"方程 2x²-5x+2=0 的解是？",opts:["x=2,x=0.5","x=2,x=-0.5","x=1,x=2","x=0.5,x=1"],ans:0,explain:"求根公式→x=[5±√(25-16)]/4=[5±3]/4→x=2或0.5。"}
  ]},
  {id:"t18",grade:9,title:"二次函数",category:"func",level:"hard",desc:"抛物线、顶点、对称轴、最值、与x轴交点——初高中衔接最重要知识点。",tags:["抛物线","顶点","最值","交点问题"],content:`
    <h4>📖 三种表达式</h4>
    <div class="formula-block"><strong>一般式：</strong>y=ax²+bx+c，对称轴x=-b/(2a)<br><strong>顶点式：</strong>y=a(x-h)²+k，顶点(h,k)<br><strong>交点式：</strong>y=a(x-x₁)(x-x₂)——已知与x轴交点时用<br>a&gt;0开口向上有最小值；a&lt;0开口向下有最大值</div>
    <div class="tip-block">💡 <strong>综合题套路：</strong>二次函数常与一元二次方程（交点）、不等式（大小比较）、几何（面积最值）结合。看到"最大/最小值"→设二次函数。Δ&gt;0→与x轴两个交点。</div>
    <div class="detail-examples">
      <div class="example-card"><div class="ex-q">例1：y=x²-4x+7的顶点</div><div class="ex-solution"><strong>解：</strong>配方→y=(x-2)²+3，顶点(2,3)。或用公式→x=-(-4)/2=2，y=4-8+7=3。<span class="ex-answer">(2,3)</span></div></div>
      <div class="example-card"><div class="ex-q">例2：二次函数y=-x²+2x+3的图像与x轴交点</div><div class="ex-solution"><strong>解：</strong>令y=0→-x²+2x+3=0→x²-2x-3=0→(x-3)(x+1)=0→交于(3,0)和(-1,0)。<span class="ex-answer">(3,0)和(-1,0)</span></div></div>
    </div>
    <h4>🧠 为什么重要</h4>
    <p>二次函数是<strong>初高中衔接最重要的知识点</strong>。高考数学中函数题占分极大，而二次函数是所有函数的基础模型。顶点、对称轴、开口方向是三个核心特征。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 对称轴公式是 x=-b/(2a)，那个负号经常被忘记。② 求最值的公式 y=(4ac-b²)/(4a)，分母也是 4a——和对称轴的分母 2a 不要搞混。</div>
    <h4>🌍 生活中的二次函数</h4>
    <p>喷泉的水柱轨迹、投掷物体的运动轨迹都是抛物线。商场利润最大化问题——定价太高卖不掉，太低不赚钱——这个"最佳定价"就是二次函数求最值。</p>
  `,questions:[
    {q:"y=x²-4x+7 的顶点坐标是？",opts:["(2,3)","(-2,3)","(2,7)","(4,7)"],ans:0,explain:"配方→y=(x-2)²+3→顶点(2,3)。"},
    {q:"y=-2(x+1)²+5的最大值是？",opts:["-1","5","3","-5"],ans:1,explain:"a&lt;0开口向下→顶点处取最大值→y_max=5。"},
    {q:"y=x²-2x-3与x轴的交点个数是？",opts:["0","1","2","3"],ans:2,explain:"Δ=4+12=16&gt;0→两个交点。判别式是判断交点个数的核心。"},
    {q:"将y=x²向右平移2个单位再向上平移3个单位，得到？",opts:["y=(x+2)²+3","y=(x-2)²+3","y=(x+2)²-3","y=x²+5"],ans:1,explain:"右移→x变x-2；上移→+3→y=(x-2)²+3。"}
  ]},
  {id:"t19",grade:9,title:"旋转",category:"geometry",level:"hard",desc:"旋转变换与中心对称——动态几何的起点，也是中考压轴题的常客。",tags:["旋转中心","旋转角","中心对称"],content:`
    <h4>📖 核心概念</h4>
    <p>将一个图形绕某点旋转一定角度。旋转三要素：<strong>旋转中心、旋转方向、旋转角度</strong>。</p>
    <div class="formula-block"><strong>旋转性质：</strong><br>① 对应点到旋转中心的距离相等<br>② 对应点与旋转中心连线夹角=旋转角<br>③ 旋转前后的图形全等（大小形状不变）</div>
    <div class="tip-block">💡 <strong>中心对称=旋转180°。</strong>中心对称的两个图形，对称点连线都过对称中心且被中心平分。看到"把某个三角形旋转"→找旋转中心→连接对应点→找等量和全等。</div>
    <h4>🧠 为什么重要</h4>
    <p>旋转是<strong>动态几何的起点</strong>，也是中考压轴题的常客。从"静态"的几何到"动态"的变换，旋转帮你建立"运动中的不变性"思维。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 旋转方向和角度的表述要准确——"顺时针旋转60°"和"逆时针旋转60°"结果完全不同。② 旋转不改变图形大小和形状，但要记住对应点连线的夹角等于旋转角。</div>
    <h4>🌍 生活中的旋转</h4>
    <p>风车转动、钟表指针的运动、汽车方向盘的转向——都是旋转。旋转门的设计、螺旋楼梯的上升路径，从几何角度看都是旋转和平移的组合。</p>
  `,questions:[
    {q:"旋转不改变图形的什么？",opts:["位置","大小和形状","方向","以上都变"],ans:1,explain:"旋转是全等变换→只改变位置和方向，不改变大小和形状。"},
    {q:"旋转180°得到的是什么变换？",opts:["平移","轴对称","中心对称","位似"],ans:2,explain:"旋转180°就是中心对称变换。"},
    {q:"点P(2,3)绕原点逆时针旋转90°后的坐标是？",opts:["(-2,3)","(-3,2)","(3,-2)","(-3,-2)"],ans:1,explain:"逆时针90°→(x,y)变成(-y,x)→(-3,2)。"}
  ]},
  {id:"t20",grade:9,title:"圆",category:"geometry",level:"hard",desc:"垂径定理、圆周角、切线——几何综合题的绝对主角。",tags:["垂径定理","圆周角","切线","弧长扇形"],content:`
    <h4>📖 核心定理</h4>
    <div class="formula-block"><strong>垂径定理：</strong>垂直于弦的直径平分弦和弦所对的两条弧<br><strong>圆周角定理：</strong>同弧所对圆周角相等=圆心角一半<br><strong>切线判定：</strong>过半径外端且垂直于半径的直线<br><strong>切线长定理：</strong>圆外一点到圆的两切线长相等</div>
    <div class="tip-block">💡 <strong>辅助线套路：</strong>见切点→连半径（垂直）；见弦→作垂径（平分）；见直径→找直角（直径所对圆周角=90°）。这三点解决大部分圆的题。</div>
    <h4>🧠 为什么重要</h4>
    <p>圆是<strong>中考几何大题的最高频考点</strong>，几乎每年必出综合题。垂径定理、圆周角定理、切线判定被称为"圆的三把钥匙"。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 圆周角定理的应用中，最关键的是找到<strong>同一条弧</strong>——弧找错了，整个推理全错。② 切线的判定必须满足两个条件：过半径外端<strong>且</strong>垂直于半径——缺一不可。</div>
    <h4>🌍 生活中的圆</h4>
    <p>车轮为什么是圆的？因为圆心到轮缘的距离始终相等——滚动时轴心保持在固定高度，行驶才平稳。钟表、井盖（不会掉下去）、圆桌——圆的"到中心等距"特性无处不在。</p>
  `,questions:[
    {q:"⊙O中弦AB=8，圆心距弦3，半径=？",opts:["5","4","7","6"],ans:0,explain:"垂径定理→构造Rt△→r²=3²+4²=25→r=5。"},
    {q:"直径所对圆周角=？",opts:["45°","60°","90°","180°"],ans:2,explain:"直径所对圆周角是直角（90°），使用频率最高的性质。"},
    {q:"半径为6的圆，圆心角为120°的弧长是？",opts:["2π","4π","6π","12π"],ans:1,explain:"弧长=2πr×角度/360°=12π×120/360=4π。"}
  ]},
  {id:"t21",grade:9,title:"相似三角形",category:"geometry",level:"hard",desc:"AA、SAS、SSS相似判定，比例线段与面积比——比例思维的核心。",tags:["AA相似","比例","面积比","位似"],content:`
    <h4>📖 判定方法</h4>
    <div class="formula-block"><strong>AA：</strong>两角对应相等（最常用！）<br><strong>SAS：</strong>两边成比例且夹角相等<br><strong>SSS：</strong>三边成比例<br>相似比k→面积比=k²，体积比=k³</div>
    <div class="tip-block">💡 <strong>找相似三大模型：</strong>A型（共角）、X型（对顶角+平行）、母子型（共角+共边）。看到平行先想相似，看到公共角两边成比例也用相似。</div>
    <h4>🧠 为什么重要</h4>
    <p>相似是<strong>比例思维的核心</strong>。地图缩放、模型制作、照片放大——这些都依赖相似。在几何证明中，相似常与全等搭配使用，是解决复杂问题的关键工具。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 面积比=相似比的<strong>平方</strong>，不是相似比本身。这是最高频的错误！② 相似和全等的区别：全等=一模一样(大小相等)，相似=形状相同但大小可能不同。</div>
    <h4>🌍 生活中的相似</h4>
    <p>手机地图缩放就是相似变换——形状不变，大小改变。根据影子算身高（阳光下的人像影子是相似三角形），建筑模型、微缩景观都是相似的实际应用。</p>
  `,questions:[
    {q:"相似三角形面积比4:9，相似比是？",opts:["2:3","4:9","16:81","3:2"],ans:0,explain:"面积比=相似比²→k²=4/9→k=2/3。"},
    {q:"△ABC中DE∥BC，AD:DB=2:3，DE:BC=？",opts:["2:3","2:5","3:5","5:2"],ans:1,explain:"AD:AB=2:5，平行→△ADE∽△ABC→DE:BC=AD:AB=2:5。"},
    {q:"判定相似最常用哪个方法？",opts:["SSS","SAS","AA","HL"],ans:2,explain:"AA（两角相等）条件最少，用得最多。"}
  ]},
  {id:"t22",grade:9,title:"锐角三角函数",category:"func",level:"hard",desc:"sin、cos、tan——三角学的入门，也是解直角三角形的利器。",tags:["sin","cos","tan","30°45°60°"],content:`
    <h4>📖 定义</h4>
    <div class="formula-block">sinA=对边/斜边；cosA=邻边/斜边；tanA=对边/邻边=sinA/cosA</div>
    <h4>🔑 特殊角函数值（必背）</h4>
    <table style="width:100%;border-collapse:collapse;text-align:center;margin:16px 0;font-size:.9rem"><tr style="background:#f1f5f9"><th>角度</th><th>30°</th><th>45°</th><th>60°</th></tr><tr><td style="padding:8px">sin</td><td>1/2</td><td>√2/2</td><td>√3/2</td></tr><tr style="background:#f8fafc"><td style="padding:8px">cos</td><td>√3/2</td><td>√2/2</td><td>1/2</td></tr><tr><td style="padding:8px">tan</td><td>√3/3</td><td>1</td><td>√3</td></tr></table>
    <div class="tip-block">💡 <strong>速记：</strong>sin30°→60°递增(½,√2/2,√3/2)，cos递减(√3/2,√2/2,½)。tan=sin÷cos。</div>
    <h4>🧠 为什么重要</h4>
    <p>三角函数是<strong>连接角度和长度的桥梁</strong>，是高中三角函数的基础。航海定位、建筑设计、物理中的力学分解都离不开 sin/cos/tan。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① sin/cos/tan<strong>只适用于直角三角形</strong>！初中阶段不要用到非直角三角形。② 记住哪条边是对边、哪条是邻边——"对边"是<strong>对着角A</strong>的那条直角边，"邻边"是<strong>挨着角A</strong>的那条直角边（不是斜边）。</div>
    <h4>🌍 生活中的三角函数</h4>
    <p>测量楼房高度——站在一定距离外测仰角，用tan就能算出高度。斜坡的坡度≈tan(坡角)。飞机的爬升角度、太阳高度角的变化——都是三角函数的实际场景。</p>
  `,questions:[
    {q:"Rt△ABC中∠C=90°，AB=10，∠A=30°，BC=？",opts:["5","5√3","10√3","20"],ans:0,explain:"sin30°=BC/10=1/2→BC=5。"},
    {q:"tan45°=？",opts:["0","1","√2","√2/2"],ans:1,explain:"tan45°=sin45°/cos45°=1。"},
    {q:"sin30°+cos60°=？",opts:["1","¼","½","2"],ans:0,explain:"sin30°=½，cos60°=½，和为1。"}
  ]},
  {id:"t23",grade:9,title:"反比例函数",category:"func",level:"hard",desc:"y=k/x 的双曲线——函数家族的特殊成员，增减性分象限讨论。",tags:["双曲线","渐近线","k的几何意义"],content:`
    <h4>📖 核心概念</h4>
    <div class="formula-block">y=k/x（k≠0），图像是<strong>双曲线</strong>，两支不在同一个象限<br>k&gt;0→在一、三象限，y随x增大而减小<br>k&lt;0→在二、四象限，y随x增大而增大<br>|k|=|xy|→图像上任一点横纵坐标乘积的绝对值=|k|</div>
    <div class="tip-block">💡 <strong>增减性要分象限讨论！</strong>不能说"k&gt;0时y随x增大而减小"——x在正半轴和负半轴上是分开讨论的。另外矩形面积=|xy|=|k|，这个几何意义中考常考。</div>
    <h4>🧠 为什么重要</h4>
    <p>反比例函数是<strong>反比关系的数学表达</strong>。很多物理量（压强与面积、电流与电阻）都是反比例关系。它的图像双曲线是所有函数中形状最独特的。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 增减性<strong>必须分象限讨论</strong>。不能说"k>0时y随x增大而减小"——在不同象限中，情况不同。② 反比例函数图像<strong>永远不会与坐标轴相交</strong>（x轴和y轴是渐近线）。</div>
    <h4>🌍 生活中的反比例</h4>
    <p>同样一笔钱，商品单价越低买得越多——总量=总价÷单价，这就是反比例。完成一项工作，人数越多需要的时间越少——工程中的反比关系。压强=力÷受力面积，也是反比例。</p>
  `,questions:[
    {q:"y=6/x的图像在哪两个象限？",opts:["一、二","一、三","二、四","三、四"],ans:1,explain:"k=6&gt;0→双曲线在一、三象限。"},
    {q:"反比例函数图像上有两点A(2,3)和B(3,m)，m=？",opts:["1","1.5","2","4.5"],ans:2,explain:"同一条双曲线上→xy=k→2×3=6→3×m=6→m=2。"}
  ]},
  {id:"t24",grade:9,title:"概率初步",category:"stats",level:"medium",desc:"古典概型、树状图与列表法——用数学的方式量化「可能性」。",tags:["古典概型","树状图","列表法","放回"],content:`
    <h4>📖 核心公式</h4>
    <div class="formula-block">P(A)=事件A包含的结果数÷所有等可能结果总数<br>0≤P(A)≤1；必然事件P=1，不可能事件P=0</div>
    <h4>🔑 方法选择</h4>
    <ol class="dp-steps"><li>一步试验→直接数</li><li>两步试验→列表法(有序)或树状图</li><li>三步及以上→树状图</li><li>注意区分"放回"和"不放回"</li></ol>
    <div class="tip-block">💡 "放回"和"不放回"的概率不同！摸球问题中放回→每次样本空间不变，不放回→样本空间每次减1。</div>
    <h4>🧠 为什么重要</h4>
    <p>概率是<strong>量化不确定性的工具</strong>。从天气预报到保险定价，从医学诊断到AI判断——概率在所有需要"预测"的领域都是核心。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① "放回"和"不放回"概率不同——摸球不放回时，第二次摸球的情况取决于第一次结果，样本空间会变化。② 概率>1或<0一定是算错了——概率永远在0到1之间。</div>
    <h4>🌍 生活中的概率</h4>
    <p>天气预报说"明天降雨概率70%"，意思是过去同样天气条件下有70%的日子下雨了。买彩票中头奖的概率是千万分之一——这就是为什么"靠彩票致富"从数学角度看是必然亏损的。</p>
  `,questions:[
    {q:"掷两枚硬币，一正一反概率？",opts:["1/4","1/2","1/3","3/4"],ans:1,explain:"4种等可能→(正正)(正反)(反正)(反反)，一正一反2种→P=1/2。"},
    {q:"3红球2白球中摸1个，摸到红球的概率？",opts:["2/5","3/5","1/2","3/2"],ans:1,explain:"红球3个共5个→P=3/5。"},
    {q:"从52张扑克中抽到A的概率？",opts:["1/52","1/13","4/52","1/4"],ans:1,explain:"4张A，52张→P=4/52=1/13。"}
  ]},
  {id:"t25",grade:9,title:"统计综合",category:"stats",level:"medium",desc:"频数直方图、扇形图、抽样推断——从数据到结论的科学方法。",tags:["直方图","扇形图","抽样","推断"],content:`
    <h4>📖 核心概念</h4>
    <p><strong>频数直方图：</strong>用面积表示频数。组距×频数=该组频数。条形图用高度，直方图用面积——这是两者的本质区别。</p>
    <div class="formula-block"><strong>扇形圆心角：</strong>某部分扇形的圆心角=该部分占比×360°</div>
    <div class="tip-block">💡 用样本估计总体是统计的核心思想。抽样的关键是<strong>随机性和代表性</strong>——样本容量越大估计越准。</div>
    <h4>🧠 为什么重要</h4>
    <p>统计综合是<strong>从数据到结论的科学方法</strong>。看懂统计图表、理解抽样误差，是现代公民的基本素养。大数据时代，不会读数据就等于"文盲"。</p>
    <h4>🚨 常见误区</h4>
    <div class="tip-block">💡 ① 直方图和条形图的区别不是细节题——高考也考。条形图看高度（纵向），直方图看面积（高度×组距）。② 用样本估计总体时，样本<strong>必须随机且足够多</strong>，否则结论可能完全错误。</div>
    <h4>🌍 生活中的统计</h4>
    <p>每次选举的民调就是"用样本估总体"——随机抽样几千人的意见来推测几千万人的选择。QC质量管理中，抽检少数产品来判断整批是否合格，也是同样的统计学原理。</p>
  `,questions:[
    {q:"某班40人中优秀12人，扇形图中优秀扇形的圆心角=？",opts:["30°","54°","72°","108°"],ans:3,explain:"12/40×360°=108°。"},
    {q:"直方图与条形图的主要区别是？",opts:["颜色不同","一个用面积一个用高度","没区别","方向不同"],ans:1,explain:"条形图用高度表示数据，直方图用面积（高度×组距）表示频数。"}
  ]}
];

/* ===== STATE ===== */
const STORE_KEY='mathStudyV2';
const state = JSON.parse(localStorage.getItem(STORE_KEY)||'{}');
function saveState(){localStorage.setItem(STORE_KEY,JSON.stringify(state))}
function getTS(id){return state[id]||{correct:0,total:0,qIdx:0}}
function setTS(id,s){state[id]=s;saveState()}

let currentGrade='all',quizTopic=null,quizQ=null,quizAnswered=false;

function renderTopics(){
  const grid=document.getElementById('topicsGrid');
  const filtered=currentGrade==='all'?topics:topics.filter(t=>t.grade===parseInt(currentGrade));
  document.getElementById('topicCount').textContent=`共 ${filtered.length} 个重难点`;
  if(!filtered.length){grid.innerHTML='<div style="text-align:center;padding:60px;color:#94a3b8"><p>该年级暂无知识点</p></div>';return}
  grid.innerHTML=filtered.map(t=>{
    const ts=getTS(t.id);
    const pct=ts.total>0?Math.round(ts.correct/ts.total*100):0;
    const qCount=t.questions.length;
    return `<div class="topic-card" onclick="openDetail('${t.id}')">
      <div class="topic-header">
        <span class="topic-icon ${t.category}">${{algebra:'𝒙',geometry:'△',func:'ƒ',stats:'📊'}[t.category]}</span>
        <span class="topic-level ${t.level}">${{basic:'基础',medium:'进阶',hard:'重难点'}[t.level]}</span>
      </div>
      <h3>${t.title}</h3>
      <p class="topic-desc">${t.desc}</p>
      <div class="topic-tags">${t.tags.map(tg=>`<span class="topic-tag">${tg}</span>`).join('')}${qCount?`<span class="topic-tag" style="background:#eef2ff;color:#6366f1">${qCount}题</span>`:''}</div>
      ${ts.total>0?`<div class="topic-progress"><div class="topic-progress-bar" style="width:${pct}%"></div></div>`:''}
    </div>`;
  }).join('');
  updateProgress();
}

function openDetail(id){
  const t=topics.find(x=>x.id===id);if(!t)return;
  const ts=getTS(id),grades=['','初一','初二','初三'];
  document.getElementById('detailPanel').innerHTML=`
    <div class="dp-top"><h2 class="dp-title">${t.title}</h2><button class="dp-close" onclick="closeDetail()">✕</button></div>
    <div class="dp-body">
      <div class="dp-meta"><span>📘 ${grades[t.grade]}</span><span>🏷 ${t.category==='algebra'?'代数':t.category==='geometry'?'几何':t.category==='func'?'函数':'统计概率'}</span><span>📝 ${t.questions.length}道练习题</span><span>${ts.total>0?`✅ ${ts.correct}/${ts.total}正确`:'未练习'}</span></div>
      <div class="dp-content">${t.content}</div>
      <div style="margin-top:24px"><button class="btn btn-primary" onclick="startQuiz('${id}')">🎯 去练习（${t.questions.length}题）</button>${ts.total>0?` <button class="btn btn-outline" onclick="resetTopic('${id}')">🔄 重新学习</button>`:''}</div>
    </div>`;
  document.getElementById('detailOverlay').classList.add('open');
}
function closeDetail(){document.getElementById('detailOverlay').classList.remove('open')}
document.getElementById('detailOverlay').addEventListener('click',function(e){if(e.target===this)closeDetail()});
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeDetail()});

function startQuiz(id){
  quizTopic=id;const t=topics.find(x=>x.id===id);if(!t)return;
  const ts=getTS(id);quizQ=t.questions[ts.qIdx%t.questions.length];quizAnswered=false;
  document.getElementById('quizArea').scrollIntoView({behavior:'smooth'});renderQuiz();closeDetail();renderTopics();
}
function renderQuiz(){
  const q=quizQ;const area=document.getElementById('quizArea');
  if(!q){document.getElementById('quizQuestion').innerHTML='<span class="q-meta">待选题</span>点击知识点卡片中的「去练习」按钮开始';document.getElementById('quizOptions').innerHTML='';document.getElementById('quizFeedback').className='quiz-feedback';document.getElementById('quizActions').innerHTML='';return}
  const t=topics.find(x=>x.id===quizTopic);const ts=getTS(quizTopic);
  const qi=(ts.qIdx%t.questions.length)+1;
  document.getElementById('quizQuestion').innerHTML=`<span class="q-meta">第 ${qi}/${t.questions.length} 题</span>${q.q}`;
  const labels='ABCDEFGH';
  document.getElementById('quizOptions').innerHTML=q.opts.map((o,i)=>`<label class="quiz-option" data-idx="${i}"><span class="opt-letter">${labels[i]}</span><span>${o}</span></label>`).join('');
  document.getElementById('quizFeedback').className='quiz-feedback';document.getElementById('quizFeedback').textContent='';
  document.getElementById('quizActions').innerHTML=`
    <button class="btn btn-primary" id="btnCheck" onclick="checkAnswer()" disabled>✅ 提交答案</button>
    <button class="btn btn-outline" onclick="nextQuestion()">⏭ 下一题</button>
    <button class="btn btn-outline btn-sm" onclick="closeQuiz()">📋 回到列表</button>`;
  document.querySelectorAll('.quiz-option').forEach(el=>{el.addEventListener('click',function(){if(quizAnswered)return;document.querySelectorAll('.quiz-option').forEach(e=>e.classList.remove('selected'));this.classList.add('selected');document.getElementById('btnCheck').disabled=false})});
}
function checkAnswer(){
  if(quizAnswered||!quizQ||!quizTopic)return;
  const sel=document.querySelector('.quiz-option.selected');if(!sel)return;
  const idx=parseInt(sel.dataset.idx),correct=idx===quizQ.ans;quizAnswered=true;
  const ts=getTS(quizTopic);ts.total++;if(correct)ts.correct++;ts.qIdx++;setTS(quizTopic,ts);
  document.querySelectorAll('.quiz-option').forEach(el=>{const i=parseInt(el.dataset.idx);if(i===quizQ.ans)el.classList.add('correct');if(i===idx&&!correct)el.classList.add('wrong');el.style.pointerEvents='none'});
  const fb=document.getElementById('quizFeedback');fb.className='quiz-feedback show '+(correct?'success':'fail');
  fb.innerHTML=correct?'✅ 回答正确！':`❌ 回答错误<br><div class="fb-steps"><strong>📝 解析：</strong>${quizQ.explain}</div>`;
  document.getElementById('btnCheck').disabled=true;updateProgress();
}
function nextQuestion(){if(!quizTopic)return;const t=topics.find(x=>x.id===quizTopic);if(!t)return;const ts=getTS(quizTopic);quizQ=t.questions[ts.qIdx%t.questions.length];quizAnswered=false;renderQuiz()}
function closeQuiz(){quizTopic=null;quizQ=null;quizAnswered=false;document.getElementById('quizQuestion').innerHTML='<span class="q-meta">待选题</span>点击知识点卡片中的「去练习」按钮开始';document.getElementById('quizOptions').innerHTML='';document.getElementById('quizFeedback').className='quiz-feedback';document.getElementById('quizActions').innerHTML='';renderTopics()}
function resetTopic(id){setTS(id,{correct:0,total:0,qIdx:0});if(quizTopic===id)closeQuiz();else renderTopics();closeDetail()}

function updateProgress(){
  const mastered=topics.filter(t=>{const ts=getTS(t.id);return ts.total>0&&ts.correct>=Math.min(3,ts.total)}).length;
  const attempted=topics.filter(t=>getTS(t.id).total>0).length;
  const totalQ=topics.reduce((s,t)=>s+getTS(t.id).total,0);
  const correctQ=topics.reduce((s,t)=>s+getTS(t.id).correct,0);
  const pct=topics.length>0?Math.round(mastered/topics.length*100):0;
  document.getElementById('statTotal').textContent=topics.length;
  document.getElementById('statMastered').textContent=mastered;
  document.getElementById('statAttempted').textContent=attempted;
  document.getElementById('statAccuracy').textContent=totalQ>0?Math.round(correctQ/totalQ*100)+'%':'--';
  document.getElementById('progressFill').style.width=pct+'%';
  document.getElementById('navMastered').textContent=mastered;
}

document.getElementById('gradeTabs').addEventListener('click',function(e){if(!e.target.classList.contains('grade-tab'))return;document.querySelectorAll('.grade-tab').forEach(b=>b.classList.remove('active'));e.target.classList.add('active');currentGrade=e.target.dataset.grade;renderTopics()});
document.querySelectorAll('.topbar nav a').forEach(a=>{a.addEventListener('click',function(e){e.preventDefault();document.querySelectorAll('.topbar nav a').forEach(x=>x.classList.remove('active'));this.classList.add('active');document.querySelector(this.getAttribute('href')).scrollIntoView({behavior:'smooth'})})});

renderTopics();

// Back to top button
const backBtn=document.createElement('button');
backBtn.className='back-to-top';backBtn.textContent='↑';backBtn.title='回到顶部';
backBtn.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));
document.body.appendChild(backBtn);
window.addEventListener('scroll',()=>{backBtn.classList.toggle('visible',window.scrollY>400)});
</script>
</body>
</html>
